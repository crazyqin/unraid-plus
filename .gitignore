# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Editor / IDE ----------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------- Go (server) ----------
server/bin/
server/dist/
server/tmp/
server/*.exe
server/*.exe~
server/*.test
server/*.out
server/coverage.out
server/coverage.txt
server/.air.toml
server/.air/
server/vendor/
*.log

# ---------- Node / Web (web) ----------
web/node_modules/
web/dist/
web/build/
web/.vite/
web/.turbo/
web/coverage/
web/.env
web/.env.local
web/.env.*.local
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*
web/pnpm-debug.log*
web/.pnpm-store/
*.tsbuildinfo

# ---------- Build artifacts ----------
*.tar.gz
*.zip
release/
dist/
build/

# Keep the go:embed target directory itself (only .gitkeep), so that
# `go:embed all:dist` still compiles on a fresh checkout. The actual frontend
# build artifacts are re-generated by `pnpm build` + `Dockerfile` and must NOT
# be committed (CI rebuilds them).
!server/internal/web/dist/
server/internal/web/dist/*
!server/internal/web/dist/.gitkeep

# ---------- Docker ----------
.docker/

# ---------- Local secrets / configs ----------
*.local
.env.local
.env.production
secrets/
*.pem
*.key
!**/testdata/*.pem

# ---------- Temp / agent ----------
.temp/
.cache/
